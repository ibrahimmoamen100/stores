{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "npm-run-all --parallel dev server",
    "server": "tsx src/server/index.ts",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "build": "tsc && vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "clean": "rm -rf node_modules/.vite dist",
    "dev:clean": "npm run clean && npm run dev",
    "build:clean": "npm run clean && npm run build",
    "kill-port": "taskkill //F //PID $(netstat -ano | findstr :3000 | awk '{print $5}' | head -1) 2>nul || echo 'No process found on port 3000'",
    "dev:fresh": "npm run kill-port && npm run clean && npm run dev"
  },
